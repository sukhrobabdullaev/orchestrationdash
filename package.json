{
  "name": "agentforge",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter @agentforge/db db:migrate",
    "db:seed": "pnpm --filter @agentforge/db db:seed",
    "db:studio": "pnpm --filter @agentforge/db db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "msgpackr-extract"
    ]
  }
}
